    },
    {
      "label": "git commit no verified",
      "type": "shell",
      "command": "git commit --no-verify -m 'jqknono定制'"
    },
    {
      "label": "build docker image",
      "type": "shell",
      "command": "make build-docker CHANNEL='development' VERSION='0.0.1' DOCKER_IMAGE_NAME='adguardhome' DOCKER_OUTPUT='type=image,name=docker.io/jqknono/adguardhome:v1.0,push=false'"
    }
  ]
