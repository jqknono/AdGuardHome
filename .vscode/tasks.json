{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "customize build",
      "type": "shell",
      "command": "bash customize.sh"
    },
    {
      "label": "push to jqknono/adguardhome:v1.0",
      "type": "shell",
      "command": "docker image import AdGuardHome_linux_amd64.tar.gz jqknono/adguardhome:v1.0 && docker image push jqknono/adguardhome:v1.0"
    },
    {
      "label": "git commit no verified",
      "type": "shell",
      "command": "git commit --no-verify -m 'jqknono定制'"
    },
    {
      "label": "build docker image",
      "type": "shell",
      "command": "make build-docker"
    }
  ]
}
